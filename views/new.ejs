<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
</head>
<body>
    <h3>Write New Chat..</h3>
    <form action="/chats" method="post">
        <input type="text" placeholder="Who are you?" name="from"><br><br>
        <textarea name="msg" placeholder="Write your message here.."></textarea><br><br>
        <input type="text" placeholder="Add receiver" name="to"><br><br>
        <button type="submit">Create Chat</button>
    </form>
</body>
</html>